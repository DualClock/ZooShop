<Window x:Class="ZooShop.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ZooShop — Регистрация" Height="760" Width="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F3F3F3">
    <Window.Resources>
        <Style x:Key="InputBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>
        <Style x:Key="InputTextBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style x:Key="InputPasswordBox" TargetType="PasswordBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1E1E2D"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="White"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2D2D44"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White" Margin="30" Padding="36,30,36,30">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
            <StackPanel>
                <!-- Заголовок -->
                <TextBlock Text="Регистрация" FontSize="26" FontWeight="SemiBold"
                           Foreground="#1E1E2D" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="Создайте аккаунт сотрудника" FontSize="13" Foreground="#888"
                           HorizontalAlignment="Center" Margin="0,0,0,24"/>

                <TextBlock Text="Фамилия" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
                <Border Style="{StaticResource InputBorder}">
                    <TextBox x:Name="TxtLastName" Style="{StaticResource InputTextBox}"/>
                </Border>

                <TextBlock Text="Имя" FontSize="12" Foreground="#555" Margin="0,12,0,4"/>
                <Border Style="{StaticResource InputBorder}">
                    <TextBox x:Name="TxtFirstName" Style="{StaticResource InputTextBox}"/>
                </Border>

                <TextBlock Text="Отчество" FontSize="12" Foreground="#555" Margin="0,12,0,4"/>
                <Border Style="{StaticResource InputBorder}">
                    <TextBox x:Name="TxtMiddleName" Style="{StaticResource InputTextBox}"/>
                </Border>

                <TextBlock Text="Телефон" FontSize="12" Foreground="#555" Margin="0,12,0,4"/>
                <Border Style="{StaticResource InputBorder}">
                    <TextBox x:Name="TxtPhone" Style="{StaticResource InputTextBox}"/>
                </Border>

                <TextBlock Text="Email (будет логином)" FontSize="12" Foreground="#555" Margin="0,12,0,4"/>
                <Border Style="{StaticResource InputBorder}">
                    <TextBox x:Name="TxtEmail" Style="{StaticResource InputTextBox}"/>
                </Border>

                <TextBlock Text="Должность" FontSize="12" Foreground="#555" Margin="0,12,0,4"/>
                <Border Style="{StaticResource InputBorder}">
                    <TextBox x:Name="TxtPosition" Style="{StaticResource InputTextBox}"/>
                </Border>

                <TextBlock Text="Пароль" FontSize="12" Foreground="#555" Margin="0,12,0,4"/>
                <Border Style="{StaticResource InputBorder}">
                    <PasswordBox x:Name="TxtPassword" Style="{StaticResource InputPasswordBox}"/>
                </Border>

                <TextBlock Text="Подтверждение пароля" FontSize="12" Foreground="#555" Margin="0,12,0,4"/>
                <Border Style="{StaticResource InputBorder}">
                    <PasswordBox x:Name="TxtPasswordConfirm" Style="{StaticResource InputPasswordBox}"/>
                </Border>

                <!-- Ошибка -->
                <TextBlock x:Name="TxtError" Foreground="#E53E3E" FontSize="12"
                           TextWrapping="Wrap" Margin="0,10,0,8" MinHeight="18" Visibility="Collapsed"/>

                <!-- Кнопка -->
                <Button Content="Зарегистрироваться"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,4,0,14"
                        Click="BtnRegister_Click"/>

                <TextBlock HorizontalAlignment="Center" Margin="0,4,0,10">
                    <Run Text="Уже есть аккаунт? " Foreground="#999" FontSize="12"/>
                    <Hyperlink Foreground="#1E1E2D" FontSize="12" Click="HyperlinkLogin_Click"
                               TextDecorations="None">Войти</Hyperlink>
                </TextBlock>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
