<Window x:Class="ZooShop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ZooShop — Вход" Height="460" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F3F3F3">
    <Window.Resources>
        <Style x:Key="InputBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>
        <Style x:Key="InputTextBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style x:Key="InputPasswordBox" TargetType="PasswordBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1E1E2D"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="White"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2D2D44"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White" Margin="30" Padding="36,40,36,36">
        <StackPanel>
            <!-- Заголовок -->
            <TextBlock Text="ZooShop" FontSize="30" FontWeight="SemiBold"
                       Foreground="#1E1E2D" HorizontalAlignment="Center" Margin="0,0,0,4"/>
            <TextBlock Text="Вход в систему" FontSize="13" Foreground="#888"
                       HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <!-- Логин -->
            <TextBlock Text="Email или телефон" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
            <Border Style="{StaticResource InputBorder}">
                <TextBox x:Name="TxtLogin" Style="{StaticResource InputTextBox}"
                         TextChanged="TxtLogin_TextChanged"/>
            </Border>

            <!-- Пароль -->
            <TextBlock Text="Пароль" FontSize="12" Foreground="#555" Margin="0,14,0,4"/>
            <Border Style="{StaticResource InputBorder}">
                <PasswordBox x:Name="TxtPassword" Style="{StaticResource InputPasswordBox}"
                             PasswordChanged="TxtPassword_PasswordChanged"/>
            </Border>

            <!-- Сообщение об ошибке -->
            <TextBlock x:Name="TxtError" Foreground="#E53E3E" FontSize="12"
                       TextWrapping="Wrap" Margin="0,10,0,0" MinHeight="18" Visibility="Collapsed"/>

            <!-- Кнопка входа -->
            <Button x:Name="BtnLogin" Content="Войти" IsDefault="True"
                    Style="{StaticResource PrimaryButton}"
                    Margin="0,18,0,14"
                    Click="BtnLogin_Click"/>

            <!-- Ссылка на регистрацию -->
            <TextBlock HorizontalAlignment="Center" Margin="0,6,0,0">
                <Run Text="Нет аккаунта? " Foreground="#999" FontSize="12"/>
                <Hyperlink Foreground="#1E1E2D" FontSize="12" Click="HyperlinkRegister_Click"
                           TextDecorations="None">Зарегистрироваться</Hyperlink>
            </TextBlock>
        </StackPanel>
    </Border>
</Window>
