<UserControl x:Class="ZooShop.Views.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ZooShop.Views"
             Padding="0">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Склад и остатки" Style="{StaticResource PageTitle}"/>

            <!-- Склад и остатки -->
            <GroupBox Header="Остатки на складе">
                <StackPanel>
                    <WrapPanel>
                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Text="Склад" Style="{StaticResource Subtitle}"/>
                            <ComboBox ItemsSource="{Binding Warehouses}" DisplayMemberPath="WarehouseName"
                                      SelectedValuePath="WarehouseID" SelectedValue="{Binding SelectedWarehouseId}"
                                      MinWidth="220"/>
                        </StackPanel>
                        <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,0">
                            <TextBlock Text=" " Style="{StaticResource Subtitle}"/>
                            <Button Content="Обновить" Command="{Binding LoadStockCommand}"
                                    Padding="16,8"/>
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
            </GroupBox>

            <!-- Текущие остатки -->
            <TextBlock Text="{Binding Stocks.Count, StringFormat=Позиций: {0}}"
                       Style="{StaticResource Subtitle}" Margin="0,0,0,8"/>
            <DataGrid ItemsSource="{Binding Stocks}" AutoGenerateColumns="False"
                      IsReadOnly="True" MaxHeight="250">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="*"/>
                    <DataGridTextColumn Header="Количество" Binding="{Binding CurrentQuantity}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Новое движение -->
            <GroupBox Header="Движение товаров">
                <StackPanel>
                    <WrapPanel>
                        <StackPanel Margin="0,0,16,10">
                            <TextBlock Text="Товар" Style="{StaticResource Subtitle}"/>
                            <ComboBox ItemsSource="{Binding Products}" DisplayMemberPath="ProductName"
                                      SelectedItem="{Binding SelectedProductForm}"
                                      MinWidth="220"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,16,10">
                            <TextBlock Text="Тип" Style="{StaticResource Subtitle}"/>
                            <ComboBox Text="{Binding MovementType}" MinWidth="140" IsEditable="True">
                                <ComboBoxItem Content="Приход"/>
                                <ComboBoxItem Content="Расход"/>
                                <ComboBoxItem Content="Списание"/>
                                <ComboBoxItem Content="Перемещение"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Margin="0,0,16,10">
                            <TextBlock Text="Количество" Style="{StaticResource Subtitle}"/>
                            <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                                     MinWidth="100"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,16,10">
                            <TextBlock Text="Цена" Style="{StaticResource Subtitle}"/>
                            <TextBox Text="{Binding UnitPrice, UpdateSourceTrigger=PropertyChanged}"
                                     MinWidth="100"/>
                        </StackPanel>
                    </WrapPanel>
                    <WrapPanel>
                        <StackPanel Margin="0,0,16,10">
                            <TextBlock Text="Документ" Style="{StaticResource Subtitle}"/>
                            <TextBox Text="{Binding DocumentNumber, UpdateSourceTrigger=PropertyChanged}"
                                     MinWidth="160"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,16,10">
                            <TextBlock Text="Примечание" Style="{StaticResource Subtitle}"/>
                            <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                     MinWidth="220"/>
                        </StackPanel>
                        <StackPanel VerticalAlignment="Bottom">
                            <TextBlock Text=" " Style="{StaticResource Subtitle}"/>
                            <Button Content="Провести" Command="{Binding SubmitMovementCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Padding="24,9" FontSize="14"/>
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
            </GroupBox>

            <!-- Движения -->
            <TextBlock Text="Последние 50 движений" Style="{StaticResource Subtitle}" Margin="0,0,0,8"/>
            <DataGrid ItemsSource="{Binding Movements}" AutoGenerateColumns="False"
                      IsReadOnly="True" MaxHeight="250"
                      SelectedItem="{Binding SelectedMovement}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Дата" Binding="{Binding MovementDate, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="150"/>
                    <DataGridTextColumn Header="Товар" Binding="{Binding Product.ProductName}" Width="*"/>
                    <DataGridTextColumn Header="Тип" Binding="{Binding MovementType}" Width="110"/>
                    <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="80"/>
                    <DataGridTextColumn Header="Склад" Binding="{Binding Warehouse.WarehouseName}" Width="130"/>
                    <DataGridTextColumn Header="Примечание" Binding="{Binding Notes}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource StatusText}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
