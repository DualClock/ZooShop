<UserControl x:Class="ZooShop.Views.EmployeesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ZooShop.Views"
             Padding="0">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Сотрудники" Style="{StaticResource PageTitle}"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Список сотрудников -->
                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <GroupBox Header="Список">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Button Content="Обновить" Command="{Binding LoadEmployeesCommand}"
                                        Padding="14,7" Margin="0,0,12,0"/>
                                <CheckBox Content="Показать неактивных" IsChecked="{Binding ShowInactive}"
                                          VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource StatusText}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <DataGrid ItemsSource="{Binding Employees}"
                                      SelectedItem="{Binding SelectedEmployee}"
                                      AutoGenerateColumns="False" IsReadOnly="True" MaxHeight="500">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="120"/>
                                    <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="110"/>
                                    <DataGridTextColumn Header="Отчество" Binding="{Binding MiddleName}" Width="120"/>
                                    <DataGridTextColumn Header="Должность" Binding="{Binding Position}" Width="120"/>
                                    <DataGridTextColumn Header="Роль" Binding="{Binding Role}" Width="100"/>
                                    <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="130"/>
                                    <DataGridTextColumn Header="Активен" Binding="{Binding IsActive}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>

                <!-- Форма -->
                <StackPanel Grid.Column="1">
                    <GroupBox Header="{Binding IsEditingMode, Converter={StaticResource BoolToFormHeaderConverter}, ConverterParameter='Сотрудник', FallbackValue='Новый сотрудник'}">
                        <StackPanel>
                            <TextBlock Text="Имя" Style="{StaticResource Subtitle}"/>
                            <TextBox Text="{Binding FormFirstName, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,10"/>

                            <TextBlock Text="Фамилия" Style="{StaticResource Subtitle}"/>
                            <TextBox Text="{Binding FormLastName, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,10"/>

                            <TextBlock Text="Отчество" Style="{StaticResource Subtitle}"/>
                            <TextBox Text="{Binding FormMiddleName, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,10"/>

                            <TextBlock Text="Телефон" Style="{StaticResource Subtitle}"/>
                            <TextBox Text="{Binding FormPhone, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,10"/>

                            <TextBlock Text="Email" Style="{StaticResource Subtitle}"/>
                            <TextBox Text="{Binding FormEmail, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,10"/>

                            <TextBlock Text="Должность" Style="{StaticResource Subtitle}"/>
                            <TextBox Text="{Binding FormPosition, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,10"/>

                            <TextBlock Text="Роль" Style="{StaticResource Subtitle}"/>
                            <ComboBox SelectedItem="{Binding FormRole}" Margin="0,0,0,10">
                                <ComboBoxItem Content="Админ"/>
                                <ComboBoxItem Content="Сотрудник"/>
                            </ComboBox>

                            <CheckBox Content="Активен" IsChecked="{Binding FormIsActive}"
                                      Margin="0,0,0,16"/>

                            <StackPanel Orientation="Horizontal">
                                <Button Content="Сохранить" Command="{Binding SaveEmployeeCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        Margin="0,0,8,0" Padding="16,8"/>
                                <Button Content="Деактивировать" Command="{Binding DeleteEmployeeCommand}"
                                        Margin="0,0,8,0" Padding="12,8"
                                        BorderBrush="#D13438" Foreground="#D13438"/>
                                <Button Content="Очистить" Command="{Binding ClearFormCommand}"
                                        Padding="12,8"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
