<UserControl x:Class="ZooShop.Views.CatalogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ZooShop.Views"
             Padding="0">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Каталог товаров" Style="{StaticResource PageTitle}"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Левая часть: Список товаров -->
                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <!-- Фильтры -->
                    <GroupBox Header="Поиск и фильтры">
                        <StackPanel>
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.ToolTip>
                                    <ToolTip>Поиск по названию или артикулу</ToolTip>
                                </TextBox.ToolTip>
                            </TextBox>

                            <WrapPanel Margin="0,12,0,0">
                                <StackPanel Margin="0,0,16,0">
                                    <TextBlock Text="Бренд" Style="{StaticResource Subtitle}"/>
                                    <ComboBox ItemsSource="{Binding Brands}" DisplayMemberPath="BrandName"
                                              SelectedValuePath="BrandID" SelectedValue="{Binding SelectedBrandId}"
                                              MinWidth="160"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,16,0">
                                    <TextBlock Text="Категория" Style="{StaticResource Subtitle}"/>
                                    <ComboBox ItemsSource="{Binding Categories}" DisplayMemberPath="CategoryName"
                                              SelectedValuePath="CategoryID" SelectedValue="{Binding SelectedCategoryId}"
                                              MinWidth="160"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,16,0">
                                    <TextBlock Text="Вид животного" Style="{StaticResource Subtitle}"/>
                                    <ComboBox ItemsSource="{Binding AnimalTypes}" DisplayMemberPath="TypeName"
                                              SelectedValuePath="AnimalTypeID" SelectedValue="{Binding SelectedAnimalTypeId}"
                                              MinWidth="160"/>
                                </StackPanel>
                                <StackPanel VerticalAlignment="Bottom">
                                    <TextBlock Text=" " Style="{StaticResource Subtitle}"/>
                                    <Button Content="Сбросить" Command="{Binding ClearFiltersCommand}"
                                            Padding="16,8"/>
                                </StackPanel>
                            </WrapPanel>
                        </StackPanel>
                    </GroupBox>

                    <!-- Список товаров -->
                    <TextBlock Text="{Binding Products.Count, StringFormat=Найдено товаров: {0}}"
                               Style="{StaticResource Subtitle}" Margin="0,0,0,8"/>

                    <DataGrid ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}"
                              AutoGenerateColumns="False" IsReadOnly="True" MaxHeight="300"
                              SelectionChanged="ProductsGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Артикул" Binding="{Binding SKU}" Width="110"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Бренд" Binding="{Binding Brand.BrandName}" Width="110"/>
                            <DataGridTextColumn Header="Категория" Binding="{Binding Category.CategoryName}" Width="110"/>
                            <DataGridTextColumn Header="Для кого" Binding="{Binding AnimalType.TypeName}" Width="100"/>
                            <DataGridTextColumn Header="Ед." Binding="{Binding Unit}" Width="55"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Карточка товара -->
                    <GroupBox Header="Остатки" Padding="16,12" Margin="0,0,0,0"
                              Visibility="{Binding SelectedProduct, Converter={StaticResource NullToVisibilityConverter}}">
                        <StackPanel DataContext="{Binding SelectedProductStock}">
                            <TextBlock Text="{Binding ProductName}" FontSize="15" FontWeight="SemiBold"
                                       Margin="0,0,0,10" Foreground="#1A1A1A"
                                       Visibility="{Binding ProductName, Converter={StaticResource NullToVisibilityConverter}}"/>
                            <ItemsControl ItemsSource="{Binding Stocks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,4">
                                            <TextBlock Text="{Binding WarehouseName}" Width="160" Foreground="#555"/>
                                            <TextBlock Text="{Binding CurrentQuantity, StringFormat={}{0} шт}"
                                                       FontWeight="SemiBold" Foreground="#333"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </GroupBox>

                    <Button Content="В чек" Command="{Binding AddToCartCommand}"
                            Style="{StaticResource PrimaryButton}" Margin="0,16,0,0"
                            Padding="24,10" FontSize="14"/>
                </StackPanel>

                <!-- Правая часть: Форма создания/редактирования товара -->
                <StackPanel Grid.Column="1">
                    <GroupBox Header="{Binding IsEditingMode, Converter={StaticResource BoolToFormHeaderConverter}, ConverterParameter='Новый товар', FallbackValue='Новый товар'}">
                        <StackPanel>
                            <TextBlock Text="Артикул" Style="{StaticResource Subtitle}"/>
                            <TextBox Text="{Binding FormSku, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,12"/>

                            <TextBlock Text="Название" Style="{StaticResource Subtitle}"/>
                            <TextBox Text="{Binding FormProductName, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,12"/>

                            <TextBlock Text="Описание" Style="{StaticResource Subtitle}"/>
                            <TextBox Text="{Binding FormDescription, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,12" TextWrapping="Wrap" MinHeight="50"/>

                            <TextBlock Text="Состав" Style="{StaticResource Subtitle}"/>
                            <TextBox Text="{Binding FormComposition, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,12" TextWrapping="Wrap" MinHeight="50"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Бренд" Style="{StaticResource Subtitle}" VerticalAlignment="Center"/>
                                <Button Content="+" ToolTip="Создать новый бренд"
                                        Command="{Binding ShowNewBrandCommand}"
                                        FontSize="12" Padding="6,2" Margin="8,0,0,0" MinWidth="20"/>
                            </StackPanel>
                            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6"
                                    Padding="12,10" Margin="0,0,0,12"
                                    Background="#FAFAFA"
                                    Visibility="{Binding ShowNewBrandForm, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="Введите название бренда" Style="{StaticResource Subtitle}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding NewBrandName, UpdateSourceTrigger=PropertyChanged}" Padding="8,5" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Сохранить" Command="{Binding SaveNewBrandCommand}"
                                                Style="{StaticResource PrimaryButton}" Padding="12,6" FontSize="11" Margin="0,0,6,0"/>
                                        <Button Content="Отмена" Command="{Binding CancelNewBrandCommand}" Padding="12,6" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <ComboBox ItemsSource="{Binding Brands}" DisplayMemberPath="BrandName"
                                      SelectedValuePath="BrandID" SelectedValue="{Binding FormBrandId}"
                                      Margin="0,0,0,12"
                                      Visibility="{Binding ShowNewBrandForm, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>

                            <TextBlock Text="Категория" Style="{StaticResource Subtitle}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text=" " Style="{StaticResource Subtitle}" VerticalAlignment="Center"/>
                                <Button Content="+" ToolTip="Создать новую категорию"
                                        Command="{Binding ShowNewCategoryCommand}"
                                        FontSize="12" Padding="6,2" Margin="0,0,0,0" MinWidth="20"/>
                            </StackPanel>
                            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6"
                                    Padding="12,10" Margin="0,0,0,12"
                                    Background="#FAFAFA"
                                    Visibility="{Binding ShowNewCategoryForm, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="Введите название категории" Style="{StaticResource Subtitle}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding NewCategoryName, UpdateSourceTrigger=PropertyChanged}" Padding="8,5" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Сохранить" Command="{Binding SaveNewCategoryCommand}"
                                                Style="{StaticResource PrimaryButton}" Padding="12,6" FontSize="11" Margin="0,0,6,0"/>
                                        <Button Content="Отмена" Command="{Binding CancelNewCategoryCommand}" Padding="12,6" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <ComboBox ItemsSource="{Binding Categories}" DisplayMemberPath="CategoryName"
                                      SelectedValuePath="CategoryID" SelectedValue="{Binding FormCategoryId}"
                                      Margin="0,0,0,12"
                                      Visibility="{Binding ShowNewCategoryForm, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Вид животного" Style="{StaticResource Subtitle}" VerticalAlignment="Center"/>
                                <Button Content="+" ToolTip="Создать новый вид"
                                        Command="{Binding ShowNewAnimalTypeCommand}"
                                        FontSize="12" Padding="6,2" Margin="8,0,0,0" MinWidth="20"/>
                            </StackPanel>
                            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6"
                                    Padding="12,10" Margin="0,0,0,12"
                                    Background="#FAFAFA"
                                    Visibility="{Binding ShowNewAnimalTypeForm, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="Введите вид животного" Style="{StaticResource Subtitle}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding NewAnimalTypeName, UpdateSourceTrigger=PropertyChanged}" Padding="8,5" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Сохранить" Command="{Binding SaveNewAnimalTypeCommand}"
                                                Style="{StaticResource PrimaryButton}" Padding="12,6" FontSize="11" Margin="0,0,6,0"/>
                                        <Button Content="Отмена" Command="{Binding CancelNewAnimalTypeCommand}" Padding="12,6" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <ComboBox ItemsSource="{Binding AnimalTypes}" DisplayMemberPath="TypeName"
                                      SelectedValuePath="AnimalTypeID" SelectedValue="{Binding FormAnimalTypeId}"
                                      Margin="0,0,0,12"
                                      Visibility="{Binding ShowNewAnimalTypeForm, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>

                            <TextBlock Text="Единица" Style="{StaticResource Subtitle}"/>
                            <ComboBox Text="{Binding FormUnit, UpdateSourceTrigger=PropertyChanged}"
                                      Margin="0,0,0,12" IsEditable="True">
                                <ComboBoxItem Content="шт"/>
                                <ComboBoxItem Content="уп"/>
                                <ComboBoxItem Content="кг"/>
                                <ComboBoxItem Content="л"/>
                            </ComboBox>

                            <TextBlock Text="Цена, ₽" Style="{StaticResource Subtitle}"/>
                            <TextBox Text="{Binding FormPrice, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,16">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding SaveProductCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>

                            <StackPanel Orientation="Horizontal">
                                <Button Content="Сохранить" Command="{Binding SaveProductCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        Margin="0,0,8,0" Padding="16,8"/>
                                <Button Content="Удалить" Command="{Binding DeleteProductCommand}"
                                        Margin="0,0,8,0" Padding="14,8"
                                        BorderBrush="#D13438" Foreground="#D13438"/>
                                <Button Content="Очистить" Command="{Binding ClearFormCommand}"
                                        Padding="14,8"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </Grid>

            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource StatusText}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
