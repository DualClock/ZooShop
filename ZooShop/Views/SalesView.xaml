<UserControl x:Class="ZooShop.Views.SalesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ZooShop.Views"
             Padding="0">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Продажи" Style="{StaticResource PageTitle}"/>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Верхняя часть: Товары + Корзина + Параметры -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="280"/>
                    </Grid.ColumnDefinitions>

                    <!-- Колонка 1: Выбор товаров -->
                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <GroupBox Header="Добавить товар">
                            <StackPanel>
                                <TextBox Text="{Binding ProductSearchText, UpdateSourceTrigger=PropertyChanged}">
                                    <TextBox.ToolTip>
                                        <ToolTip>Поиск по названию или артикулу</ToolTip>
                                    </TextBox.ToolTip>
                                </TextBox>

                                <WrapPanel Margin="0,12,0,0">
                                    <StackPanel Margin="0,0,12,0">
                                        <TextBlock Text="Бренд" Style="{StaticResource Subtitle}"/>
                                        <ComboBox ItemsSource="{Binding Brands}" DisplayMemberPath="BrandName"
                                                  SelectedValuePath="BrandID" SelectedValue="{Binding ProductFilterBrandId}"
                                                  MinWidth="140"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Категория" Style="{StaticResource Subtitle}"/>
                                        <ComboBox ItemsSource="{Binding Categories}" DisplayMemberPath="CategoryName"
                                                  SelectedValuePath="CategoryID" SelectedValue="{Binding ProductFilterCategoryId}"
                                                  MinWidth="140"/>
                                    </StackPanel>
                                </WrapPanel>

                                <TextBlock Text="{Binding AvailableProducts.Count, StringFormat=Товаров: {0}}"
                                           Style="{StaticResource Subtitle}" Margin="0,12,0,8"/>

                                <DataGrid ItemsSource="{Binding AvailableProducts}"
                                          SelectedItem="{Binding SelectedAvailableProduct}"
                                          AutoGenerateColumns="False" IsReadOnly="True" MaxHeight="280"
                                          MouseDoubleClick="ProductGrid_MouseDoubleClick">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Артикул" Binding="{Binding SKU}" Width="100"/>
                                        <DataGridTextColumn Header="Название" Binding="{Binding ProductName}" Width="*"/>
                                        <DataGridTextColumn Header="Бренд" Binding="{Binding Brand.BrandName}" Width="90"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <Button Content="Добавить в чек" Command="{Binding AddProductToCartCommand}"
                                        Style="{StaticResource PrimaryButton}" Margin="0,12,0,0"
                                        Padding="20,9"/>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>

                    <!-- Колонка 2: Корзина -->
                    <StackPanel Grid.Column="1" Margin="6,0">
                        <GroupBox Header="Корзина">
                            <StackPanel>
                                <DataGrid ItemsSource="{Binding CartItems}" AutoGenerateColumns="False"
                                          IsReadOnly="True" MaxHeight="280">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Товар" Binding="{Binding Product.ProductName}" Width="*"/>
                                        <DataGridTextColumn Header="Цена" Binding="{Binding UnitPrice, StringFormat={}{0:N2}}" Width="75"/>
                                        <DataGridTemplateColumn Header="Кол-во" Width="100">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <Button Content="−" Width="24" Height="24" Padding="0"
                                                                FontSize="12"
                                                                Command="{Binding DataContext.DecreaseQtyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"/>
                                                        <TextBlock Text="{Binding Quantity}" Width="28"
                                                                   TextAlignment="Center" VerticalAlignment="Center"
                                                                   FontSize="13" FontWeight="SemiBold"/>
                                                        <Button Content="+" Width="24" Height="24" Padding="0"
                                                                FontSize="12"
                                                                Command="{Binding DataContext.IncreaseQtyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Итого" Binding="{Binding LineTotal, StringFormat={}{0:N2}}" Width="85"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="Подитог:" FontSize="13" Foreground="#555"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Subtotal, StringFormat={}{0:N2} ₽}"
                                               FontSize="14" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="Скидка:" FontSize="13" Foreground="#555"
                                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBox Text="{Binding CartDiscount, UpdateSourceTrigger=PropertyChanged}"
                                             Width="80" Padding="6,4" FontSize="13"/>
                                    <TextBlock Text="₽" FontSize="13" Foreground="#555"
                                               VerticalAlignment="Center" Margin="4,0,0,0"/>
                                </StackPanel>
                                <TextBlock Text="{Binding GrandTotal, StringFormat=Итого к оплате: {0:N2} ₽}"
                                           FontSize="18" FontWeight="SemiBold" Foreground="#107C10"
                                           Margin="0,12,0,0"/>

                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button Content="Оформить продажу" Command="{Binding CheckoutCommand}"
                                            Style="{StaticResource PrimaryButton}"
                                            Padding="20,10" Margin="0,0,8,0" FontSize="14"/>
                                    <Button Content="Очистить" Command="{Binding ClearCartCommand}"
                                            Padding="14,10" FontSize="13"
                                            BorderBrush="#D13438" Foreground="#D13438"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>

                    <!-- Колонка 3: Параметры продажи -->
                    <StackPanel Grid.Column="2" Margin="12,0,0,0">
                        <GroupBox Header="Параметры">
                            <StackPanel>
                                <!-- Клиент -->
                                <TextBlock Text="Клиент" Style="{StaticResource Subtitle}"/>
                                <ComboBox ItemsSource="{Binding Clients}"
                                          SelectedItem="{Binding SelectedClient}" Margin="0,0,0,6"
                                          Visibility="{Binding ShowNewClientForm, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>

                                <Button Content="+ Новый клиент" Padding="10,6" FontSize="12"
                                        Command="{Binding ShowNewClientFormCommand}"
                                        Visibility="{Binding ShowNewClientForm, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                        Margin="0,0,0,12" HorizontalAlignment="Left"/>

                                <!-- Форма нового клиента -->
                                <Border BorderBrush="#107C10" BorderThickness="1" Padding="12" Margin="0,0,0,12"
                                        Background="#F6FFF6" CornerRadius="6"
                                        Visibility="{Binding ShowNewClientForm, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel>
                                        <TextBlock Text="Новый клиент" FontWeight="SemiBold" Foreground="#107C10"
                                                   FontSize="14" Margin="0,0,0,10"/>
                                        <TextBlock Text="Имя" Style="{StaticResource Subtitle}"/>
                                        <TextBox Text="{Binding NewClientFirstName, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,0,0,8"/>
                                        <TextBlock Text="Фамилия" Style="{StaticResource Subtitle}"/>
                                        <TextBox Text="{Binding NewClientLastName, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,0,0,8"/>
                                        <TextBlock Text="Телефон" Style="{StaticResource Subtitle}"/>
                                        <TextBox Text="{Binding NewClientPhone, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,0,0,8"/>
                                        <TextBlock Text="Email" Style="{StaticResource Subtitle}"/>
                                        <TextBox Text="{Binding NewClientEmail, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,0,0,8"/>
                                        <TextBlock Text="Заметки" Style="{StaticResource Subtitle}"/>
                                        <TextBox Text="{Binding NewClientNotes, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,0,0,12" TextWrapping="Wrap" MinHeight="40"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Создать" Command="{Binding CreateClientCommand}"
                                                    Style="{StaticResource PrimaryButton}"
                                                    Padding="14,7" Margin="0,0,8,0" FontSize="12"/>
                                            <Button Content="Отмена" Command="{Binding CancelNewClientCommand}"
                                                    Padding="12,7" FontSize="12"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="Сотрудник" Style="{StaticResource Subtitle}"/>
                                <ComboBox ItemsSource="{Binding Employees}" SelectedItem="{Binding SelectedEmployee}"
                                          Margin="0,0,0,12"/>

                                <TextBlock Text="Склад" Style="{StaticResource Subtitle}"/>
                                <ComboBox ItemsSource="{Binding Warehouses}" SelectedItem="{Binding SelectedWarehouse}"
                                          Margin="0,0,0,12"/>

                                <TextBlock Text="Способ оплаты" Style="{StaticResource Subtitle}"/>
                                <ComboBox Text="{Binding PaymentMethod, UpdateSourceTrigger=PropertyChanged}"
                                          IsEditable="True">
                                    <ComboBoxItem Content="Наличные"/>
                                    <ComboBoxItem Content="Карта"/>
                                    <ComboBoxItem Content="Перевод"/>
                                </ComboBox>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </Grid>

                <!-- Нижняя часть: Чек -->
                <GroupBox Grid.Row="1" Header="Чек" Margin="0,16,0,0"
                          Visibility="{Binding ReceiptText, Converter={StaticResource StringNullOrEmptyToVisibilityConverter}}">
                    <TextBox Text="{Binding ReceiptText}" TextWrapping="Wrap" IsReadOnly="True"
                             FontFamily="Consolas" FontSize="12" MaxHeight="200"
                             VerticalScrollBarVisibility="Auto" BorderThickness="0"
                             Background="Transparent"/>
                </GroupBox>
            </Grid>

            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource StatusText}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
