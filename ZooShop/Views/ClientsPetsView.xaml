<UserControl x:Class="ZooShop.Views.ClientsPetsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ZooShop.Views"
             Padding="0">
    <UserControl.Resources>
        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Клиенты и питомцы" Style="{StaticResource PageTitle}"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Клиенты -->
                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <GroupBox Header="Клиенты">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Button Content="Найти" Command="{Binding SearchCommand}"
                                        Padding="14,7" Margin="0,0,8,0"/>
                                <Button Content="Сохранить" Command="{Binding SaveClientCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        Padding="14,7"/>
                            </StackPanel>

                            <TextBlock Text="Имя" Style="{StaticResource Subtitle}"/>
                            <TextBox Text="{Binding ClientFirstName, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,8"/>
                            <TextBlock Text="Фамилия" Style="{StaticResource Subtitle}"/>
                            <TextBox Text="{Binding ClientLastName, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,8"/>
                            <TextBlock Text="Телефон" Style="{StaticResource Subtitle}"/>
                            <TextBox Text="{Binding ClientPhone, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,8"/>
                            <TextBlock Text="Email" Style="{StaticResource Subtitle}"/>
                            <TextBox Text="{Binding ClientEmail, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,8"/>
                            <TextBlock Text="Заметки" Style="{StaticResource Subtitle}"/>
                            <TextBox Text="{Binding ClientNotes, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,12" TextWrapping="Wrap" MinHeight="50"/>

                            <DataGrid ItemsSource="{Binding Clients}" SelectedItem="{Binding SelectedClient}"
                                      AutoGenerateColumns="False" IsReadOnly="True" MaxHeight="200">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="*"/>
                                    <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="*"/>
                                    <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Button Content="Удалить клиента" Command="{Binding DeleteClientCommand}"
                                    Margin="0,8,0,0" Padding="14,7"
                                    BorderBrush="#D13438" Foreground="#D13438"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>

                <!-- Питомцы -->
                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                    <GroupBox Header="Питомцы">
                        <StackPanel>
                            <TextBlock Text="Кличка" Style="{StaticResource Subtitle}"/>
                            <TextBox Text="{Binding PetName, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,8"/>
                            <TextBlock Text="Вид" Style="{StaticResource Subtitle}"/>
                            <ComboBox ItemsSource="{Binding AnimalTypes}" DisplayMemberPath="TypeName"
                                      SelectedValuePath="AnimalTypeID" SelectedValue="{Binding PetAnimalTypeId}"
                                      Margin="0,0,0,8"/>
                            <TextBlock Text="Порода" Style="{StaticResource Subtitle}"/>
                            <TextBox Text="{Binding PetBreed, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,8"/>
                            <TextBlock Text="Аллергии" Style="{StaticResource Subtitle}"/>
                            <TextBox Text="{Binding PetAllergies, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,8"/>
                            <TextBlock Text="Пол" Style="{StaticResource Subtitle}"/>
                            <ComboBox Text="{Binding PetGender, UpdateSourceTrigger=PropertyChanged}"
                                      Margin="0,0,0,12" IsEditable="True">
                                <ComboBoxItem Content="Мальчик"/>
                                <ComboBoxItem Content="Девочка"/>
                            </ComboBox>

                            <StackPanel Orientation="Horizontal">
                                <Button Content="Сохранить" Command="{Binding SavePetCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        Margin="0,0,8,0" Padding="16,8"/>
                                <Button Content="Удалить" Command="{Binding DeletePetCommand}"
                                        Padding="14,8" BorderBrush="#D13438" Foreground="#D13438"/>
                            </StackPanel>

                            <DataGrid ItemsSource="{Binding Pets}" SelectedItem="{Binding SelectedPet}"
                                      AutoGenerateColumns="False" IsReadOnly="True" MaxHeight="200"
                                      Margin="0,12,0,0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Кличка" Binding="{Binding PetName}" Width="*"/>
                                    <DataGridTextColumn Header="Вид" Binding="{Binding AnimalType.TypeName}" Width="*"/>
                                    <DataGridTextColumn Header="Порода" Binding="{Binding Breed}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource StatusText}"
                                       Margin="0,10,0,0"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
