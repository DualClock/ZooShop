<UserControl x:Class="ZooShop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Padding="0">
    <UserControl.Resources>
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="BorderBrush" Value="#E8E8E8"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <!-- Заголовок -->
            <TextBlock Text="Панель управления" Style="{StaticResource PageTitle}"/>

            <!-- Статистика дня -->
            <TextBlock Text="Статистика за сегодня" Style="{StaticResource Subtitle}" Margin="0,0,0,12"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,28">
                <Border Style="{StaticResource StatCardStyle}" MinWidth="220">
                    <StackPanel>
                        <TextBlock Text="Выручка" FontSize="12" Foreground="#888" FontWeight="Normal"/>
                        <TextBlock Text="{Binding TodaySales.TotalRevenue, StringFormat={}{0:N2} ₽}"
                                   FontSize="28" FontWeight="SemiBold" Foreground="#107C10"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCardStyle}" MinWidth="220">
                    <StackPanel>
                        <TextBlock Text="Продаж" FontSize="12" Foreground="#888"/>
                        <TextBlock Text="{Binding TodaySales.TotalSales}"
                                   FontSize="28" FontWeight="SemiBold" Foreground="#0078D4"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCardStyle}" MinWidth="220">
                    <StackPanel>
                        <TextBlock Text="Средний чек" FontSize="12" Foreground="#888"/>
                        <TextBlock Text="{Binding TodaySales.AvgCheck, StringFormat={}{0:N2} ₽}"
                                   FontSize="28" FontWeight="SemiBold" Foreground="#CA5010"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCardStyle}" MinWidth="220">
                    <StackPanel>
                        <TextBlock Text="Мало на складе" FontSize="12" Foreground="#888"/>
                        <TextBlock Text="{Binding LowStockCount}"
                                   FontSize="28" FontWeight="SemiBold" Foreground="#D13438"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Быстрые действия -->
            <TextBlock Text="Быстрые действия" Style="{StaticResource Subtitle}" Margin="0,0,0,12"/>
            <WrapPanel Margin="0,0,0,28">
                <Button Content="Новая продажа" Style="{StaticResource PrimaryButton}"
                        Margin="0,0,10,8" Padding="20,10"
                        Command="{Binding NavigateCommand}" CommandParameter="Продажи"/>
                <Button Content="Каталог товаров"
                        Margin="0,0,10,8" Padding="20,10"
                        Command="{Binding NavigateCommand}" CommandParameter="Каталог"/>
                <Button Content="Остатки"
                        Margin="0,0,10,8" Padding="20,10"
                        Command="{Binding NavigateCommand}" CommandParameter="Склад"/>
                <Button Content="Клиенты"
                        Margin="0,0,10,8" Padding="20,10"
                        Command="{Binding NavigateCommand}" CommandParameter="Клиенты и питомцы"/>
            </WrapPanel>

            <!-- Топ товаров -->
            <TextBlock Text="Топ товаров" Style="{StaticResource Subtitle}" Margin="0,0,0,12"/>
            <DataGrid ItemsSource="{Binding TopProducts}" AutoGenerateColumns="False"
                      IsReadOnly="True" Margin="0,0,0,28" MaxHeight="200">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Название" Binding="{Binding ProductName}" Width="*"/>
                    <DataGridTextColumn Header="Артикул" Binding="{Binding SKU}" Width="140"/>
                    <DataGridTextColumn Header="Категория" Binding="{Binding Category.CategoryName}" Width="140"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Уведомления -->
            <TextBlock Text="Уведомления" Style="{StaticResource Subtitle}" Margin="0,0,0,12"/>
            <Border Background="#FFF4CE" CornerRadius="8" Padding="16,14"
                    BorderBrush="#FFE082" BorderThickness="1">
                <TextBlock Text="{Binding Notifications}" TextWrapping="Wrap" FontSize="13" Foreground="#333"/>
            </Border>

            <Button Content="Обновить" Command="{Binding RefreshCommand}"
                    HorizontalAlignment="Left" Style="{StaticResource PrimaryButton}"
                    Margin="0,20,0,0" Padding="24,10"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
